# openFDA (optional — increases rate limit from 240/min to 1000/min)
# Get free key at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# NCBI Entrez (required — just your email address, no registration needed)
NCBI_EMAIL=your@email.com

# NCI Cancer Data Standards Registry (caDSR) (optional)
# Get free key at: https://cadsr.cancer.gov/
NCI_CADSR_API_KEY=

# NCATS Biomedical Translator (optional)
# Get free key at: https://ncats.nih.gov/translator
NCATS_TRANSLATOR_API_KEY=

# NHGRI AnVIL (optional)
# Get free key at: https://anvil.terra.bio/
NHGRI_ANVIL_API_KEY=

# NIAID ImmPort (optional)
# Get free key at: https://www.immport.org/
NIAID_IMMPORT_API_KEY=

# NINDS NeuroMMSig (optional)
# Request access at: https://neurommsig.scai.fraunhofer.de/
NINDS_NEUROMMSIG_API_KEY=

# OMIM (optional)
# Get free key at: https://omim.org/api
OMIM_API_KEY=

# NCBI API Key (optional — increases rate limit)
# Get key at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# Financial Modeling Prep (optional)
# Get key at: https://site.financialmodelingprep.com/
FMP_API_KEY=

# NCI Clinical Trials API (optional)
# Get key at: https://clinicaltrialsapi.cancer.gov/api-v2/
NCI_API_KEY=

# NCBI Account Info (optional)
NCBI_EMAIL=your@email.com
NCBI_ACCOUNT=your@orcid

# Terra/AnVIL Account (optional)
TERRA_ACCOUNT=your@email.com

# Copy to .env and fill in values. .env is gitignored.

# Ollama Cloud API key — fallback when local Ollama is down
# Create at: https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Optional overrides
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# OLLAMA_ALLOW_LAN=1

# Other optional keys
# OPENFDA_API_KEY=
# NCBI_EMAIL=
# NCBI_API_KEY=
# OMIM_API_KEY=

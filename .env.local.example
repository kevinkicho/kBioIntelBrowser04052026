# Copy to .env (or .env.local) and fill in values.
# .env / .env.local are gitignored — never commit real keys.

# Ollama Cloud API key — fallback when local Ollama is down
# Create at: https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Optional overrides
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# OLLAMA_ALLOW_LAN=1

# Firebase web app config (Firebase console → Project settings → Your apps)
# Use NEXT_PUBLIC_ so the client SDK can read them in Next.js.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Other optional keys
# OPENFDA_API_KEY=
# NCBI_EMAIL=
# NCBI_API_KEY=
# OMIM_API_KEY=

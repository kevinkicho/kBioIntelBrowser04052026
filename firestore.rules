rules_version = '2';

// BioIntel: optional cloud sync. Solo + localStorage remains default.
// All user data is owner-only. No public read/write of research content.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // users/{uid} and subcollections
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /projects/{projectId} {
        allow read, write: if isOwner(uid);
      }
      match /settings/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /packs/{packId} {
        // Metadata only — large pack payloads stay client-local / download
        allow read, write: if isOwner(uid);
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
